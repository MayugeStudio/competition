#include <iostream>
using namespace std;
using ll = long long;


void solve() {
  int n; cin >> n;
  string s; cin >> s;
  vector<ll> x(n), y(n-1);

  for (int i=0; i<n; ++i) cin >> x[i];
  for (int i=0; i<n-1; ++i) cin >> y[i-1];
}

int main() {
  int t; cin >> t;
  while (t--) solve();
  return 0;
}
